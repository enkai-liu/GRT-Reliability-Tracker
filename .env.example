POLL_SECONDS=30
ALERT_POLL_SECONDS=300
DATA_ROOT=data

# Optional: set this to also upload saved snapshots to Google Cloud Storage.
# Example: GCS_BUCKET=grt-reliability-raw-data
GCS_BUCKET=

# Optional: delete local raw date-directories older than this many days once
# every file in them is verified present in GCS (requires GCS_BUCKET). Keeps
# the collector VM's disk from filling. Unset or 0 disables pruning.
# RAW_RETENTION_DAYS=2

# Optional: a SEPARATE, public GCS bucket the live scorer uploads
# live-predictions.json to, so a statically hosted dashboard can fetch real-time
# predictions. Keep this distinct from GCS_BUCKET (which holds private raw data).
# Example: GCS_LIVE_BUCKET=grt-reliability-live  (see ops/gcp/README.md)
GCS_LIVE_BUCKET=

BUS_TRIP_UPDATES_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/tripupdates/1
BUS_VEHICLE_POSITIONS_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/vehiclepositions/1
BUS_STATIC_GTFS_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/staticfeeds/1

LRT_TRIP_UPDATES_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/tripupdates/2
LRT_VEHICLE_POSITIONS_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/vehiclepositions/2
LRT_STATIC_GTFS_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/staticfeeds/2

GRT_SERVICE_ALERTS_URL=https://webapps.regionofwaterloo.ca/api/grt-routes/api/alerts

WEATHER_FORECAST_LOCATIONS=kitchener_waterloo:on-82,cambridge:on-81
WEATHER_FORECAST_API_URL=https://api.weather.gc.ca/collections/citypageweather-realtime/items
